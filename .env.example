# 钉钉开放平台配置
# 注册地址：https://open-dev.dingtalk.com/
# 1. 创建"企业内部应用"
# 2. 获取 AppKey 和 AppSecret
# 3. 配置"扫码登录"回调地址：http://your-domain/api/auth/dingtalk/callback
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CORP_ID=

# JWT 密钥（用于生成用户登录 Token）
JWT_SECRET=etms_jwt_secret_change_me_in_production

# 服务器端口
PORT=3000

# 管理员默认密码（首次初始化数据库时使用）
ADMIN_PASSWORD=admin123
